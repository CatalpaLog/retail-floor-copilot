# 复制为 .streamlit/secrets.toml 仅用于本地；部署到 Community Cloud 时粘贴到 App Settings > Secrets。
APP_MODE = "demo"
AUTH_MODE = "demo"
DEMO_RESET_MINUTES = 60
DEMO_SHOW_ROLE_SWITCHER = true
DEMO_ALLOW_CATALOG_WRITES = false
SIMULATED_INVENTORY = true

# 可选：设置后，访问演示页面需要输入口令。
DEMO_ACCESS_CODE = ""

# 可选：公开 FastAPI 时使用。未配置时仅建议本地运行 API。
API_DEMO_TOKEN = ""

# 可选：不填也可运行，系统会使用规则与检索兜底回答。
LLM_API_KEY = ""
LLM_BASE_URL = "https://api.openai.com/v1"
LLM_MODEL = "gpt-4.1-mini"
LLM_TIMEOUT_SECONDS = 30

RFC_BUSINESS_DATE = "2026-07-15"
RFC_TOP_K = 5
RFC_MIN_SCORE = 0.055
